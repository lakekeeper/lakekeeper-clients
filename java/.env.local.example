# Copy to java/.env.local and fill in your values.
# Used by: cd java && ./gradlew :examples:flink:run

# Lakekeeper
LAKEKEEPER=http://localhost:8181
WAREHOUSE_ID=your-warehouse-uuid

# Auth — pick one:
TOKEN=your-static-token
# OAUTH_TOKEN_URL=http://localhost:8080/realms/iceberg/protocol/openid-connect/token
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_SCOPE=lakekeeper

# Table
NAMESPACE=iot
TABLE=sensor-readings

# Tuning (all optional)
NUM_SENSORS=5
BATCH_SIZE=10
BATCH_INTERVAL_MS=15000
