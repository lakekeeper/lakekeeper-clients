# Copy to examples/.env, fill in, then load with:
#     set -a; source examples/.env; set +a
# (`set -a` auto-exports every assignment to the environment.)

# --- Server ---
LAKEKEEPER=http://localhost:8181

# The warehouse UUID — it is the URL path prefix, NOT the name.
# Get it from:  curl -s $LAKEKEEPER/management/v1/warehouse -H "Authorization: Bearer $TOKEN" \
#                    -H "x-project-id: $PROJECT_ID" | jq '.warehouses[] | {name, id}'
WAREHOUSE_ID=

# Optional; sets the x-project-id header. Default project is the nil UUID.
PROJECT_ID=00000000-0000-0000-0000-000000000000

# The example creates/reads this table. The NAMESPACE must already exist (see README).
NAMESPACE=ai.test
TABLE=image_embeddings

# --- Auth: choose ONE ---

# (A) Static bearer token. For a no-auth Lakekeeper any value works (e.g. TOKEN=dev).
TOKEN=

# (B) OAuth2 client_credentials — leave TOKEN empty to use this branch.
#OAUTH_TOKEN_URL=http://localhost:30080/realms/iceberg/protocol/openid-connect/token
#OAUTH_CLIENT_ID=spark
#OAUTH_CLIENT_SECRET=2OR3eRvYfSZzzZ16MlPd95jhLnOaLM52
#OAUTH_SCOPE=
